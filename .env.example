# Copy this file to ".env" and fill in ONE provider's key to run the agent from
# the server side (e.g. for SHL's evaluator or CLI eval). The web UI does NOT
# need this — there you paste your key in the browser instead.

# Which provider to use: groq | gemini | openrouter
LLM_PROVIDER=groq

# Your free-tier API key for that provider.
LLM_API_KEY=

# Optional: override the default model for the provider.
# groq        default: llama-3.3-70b-versatile
# gemini      default: gemini-2.0-flash
# openrouter  default: meta-llama/llama-3.3-70b-instruct:free
# LLM_MODEL=

# Optional tuning
# RETRIEVE_K=30
# LLM_TIMEOUT_SECONDS=24
